    <content type="html"><![CDATA[<p><strong>假设</strong></p><blockquote><p>账号：root<br>密码：123456</p></blockquote><h2 id="导入"><a href="#导入" class="headerlink" title="导入"></a>导入</h2><figure class="highlight bash"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs bash">mysql -uroot -p123456 database_name &lt; data.sql<br></code></pre></td></tr></table></figure><h2 id="导出"><a href="#导出" class="headerlink" title="导出"></a>导出</h2><figure class="highlight bash"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs bash">mysqldump -uroot -p123456  database_name &gt; /data/data.sql<br></code></pre></td></tr></table></figure>]]></content>
    
    
    
